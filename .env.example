# ─────────────────────────────────────────────────────────────────────────────
# .env 설정 파일 — sync.py가 자동으로 로드합니다
# 사용법: 이 파일을 복사해서 .env 로 저장 후 값을 채워넣으세요
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# Notion Integration 토큰
# 발급 위치: https://www.notion.so/my-integrations
# 형태: secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_TOKEN=secret_여기에_토큰_입력

# Notion Database ID
# URL에서 추출: notion.so/[username]/[DATABASE_ID]?v=...
# 형태: 32자리 영숫자 (하이픈 포함 또는 미포함 모두 가능)
NOTION_DB_ID=여기에_데이터베이스_ID_입력
